<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= filename %> - NotePad</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap');
        * { font-family: 'Poppins', sans-serif; }
    </style>
</head>
<body>
    <div class="main w-full min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
        <!-- Header -->
        <header class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-6 shadow-lg">
            <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <i class="fas fa-sticky-note text-2xl"></i>
                    <h1 class="text-2xl font-bold">NotePad</h1>
                </div>
                <a href="/" class="bg-white bg-opacity-20 hover:bg-opacity-30 text-white py-2 px-4 rounded-lg transition flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i>
                    Back to Home
                </a>
            </div>
        </header>

        <!-- Content -->
        <div class="py-12 px-6">
            <div class="max-w-4xl mx-auto">
                <!-- Note Card -->
                <div class="bg-gradient-to-br from-slate-700 to-slate-600 rounded-2xl shadow-2xl p-10 border border-slate-500">
                    <!-- Title -->
                    <div class="mb-8 pb-6 border-b border-slate-500">
                        <h1 class="text-4xl font-bold text-white tracking-tight break-words"><%= filename.replace('.txt', '') %></h1>
                        <div class="flex items-center gap-2 mt-3 text-slate-300 text-sm">
                            <i class="fas fa-file-alt text-blue-400"></i>
                            <span>Text Note</span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="mb-8">
                        <p class="text-slate-100 text-lg leading-relaxed whitespace-pre-wrap break-words"><%= filedata %></p>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-4 pt-6 border-t border-slate-500">
                        <a href="/edit/<%= filename %>" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white font-semibold py-3 rounded-lg transition flex items-center justify-center gap-2">
                            <i class="fas fa-edit"></i>
                            Edit Note
                        </a>
                        <a href="/" class="flex-1 bg-slate-600 hover:bg-slate-700 text-white font-semibold py-3 rounded-lg transition flex items-center justify-center gap-2">
                            <i class="fas fa-home"></i>
                            Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>